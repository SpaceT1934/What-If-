{
  "name": "what-if-universe",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "install": "npm --prefix frontend install",
    "dev": "npm --prefix frontend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "cd backend && .venv/bin/python -m uvicorn main:app --reload --host 127.0.0.1 --port 8000",
    "build": "npm --prefix frontend run build && mkdir -p dist && cp -R frontend/dist/. dist/",
    "preview": "npm --prefix frontend run preview"
  }
}
